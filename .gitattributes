# ============================================================================
# nexsys-hivemind — Line Ending Normalization
#
# Enforce LF line endings in the repository regardless of OS. This stops the
# CRLF/LF churn that produced false "modified" lists, mangled diffs, and
# index.lock friction when the repo is shared between the Windows host and a
# Linux sandbox. Mirrors homesynapse-core/.gitattributes.
#
# Apply once: commit this file, then run `git add --renormalize .` and commit
# the resulting (content-neutral) diff from HOST git.
# ============================================================================

# Default: normalize all text files to LF on commit, check out as LF
* text=auto eol=lf

# Explicitly mark binary files so Git never tries to normalize them
*.jar        binary
*.png        binary
*.jpg        binary
*.gif        binary
*.ico        binary
*.pdf        binary
*.woff       binary
*.woff2      binary
*.ttf        binary
*.eot        binary

# Windows batch files need CRLF to work on Windows
*.bat        text eol=crlf
